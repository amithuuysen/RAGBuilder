# RAGBuilder environment configuration
# Copy to .env and adjust as needed

# API base URL for the Next.js frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Backend paths
RAGBUILDER_DB_PATH=./ragbuilder.db
RAGBUILDER_QDRANT_PATH=./qdrant_db
RAGBUILDER_TEMP_DIR=./temp
RAGBUILDER_LOG_FILE=./ragbuilder.log

# Retrieval defaults
RAGBUILDER_DEFAULT_TOP_K=4
RAGBUILDER_VECTOR_WEIGHT=0.7
RAGBUILDER_KEYWORD_WEIGHT=0.3
RAGBUILDER_CHUNK_SIZE=500
RAGBUILDER_CHUNK_OVERLAP=50

# Limits
RAGBUILDER_MAX_UPLOAD_MB=50
RAGBUILDER_MAX_QUERY_LENGTH=8000
